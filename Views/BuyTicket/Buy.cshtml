@model BusBookingSystem.Models.BuyTicketViewModel

<h1>🎫 Buy Ticket</h1>

<form asp-action="Buy" method="post" style="max-width:400px; display:flex; flex-direction:column; gap:10px;">

    <div asp-validation-summary="All" style="color:red;"></div>

    <label>Ticket Duration</label>
    <select asp-for="Duration">
        <option value="">-- Select Duration --</option>
        <option value="1day">1 Day - $5</option>
        <option value="1week">1 Week - $20</option>
        <option value="1month">1 Month - $60</option>
    </select>
    <span asp-validation-for="Duration" style="color:red;"></span>

    <label>Payer Name</label>
    <input asp-for="PayerName" />
    <span asp-validation-for="PayerName" style="color:red;"></span>

    <label>Phone Number</label>
    <input asp-for="PhoneNumber" />
    <span asp-validation-for="PhoneNumber" style="color:red;"></span>

    <label>Payment Method</label>
    <select asp-for="PaymentMethod" id="paymentMethod">
        <option value="">-- Select Method --</option>
        <option value="CARD">Card</option>
    </select>
    <span asp-validation-for="PaymentMethod" style="color:red;"></span>

    <div id="cardBox" style="display:none;">
        <label>Card Last 4 Digits</label>
        <input asp-for="CardLast4" maxlength="4" />
        <span asp-validation-for="CardLast4" style="color:red;"></span>
    </div>

    <button type="submit">Confirm Purchase</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const paymentMethod = document.getElementById("paymentMethod");
        const cardBox = document.getElementById("cardBox");

        function toggleCardBox() {
            if (paymentMethod.value === "CARD") {
                cardBox.style.display = "block";
            } else {
                cardBox.style.display = "none";
            }
        }

        paymentMethod.addEventListener("change", toggleCardBox);
        toggleCardBox();
    </script>
}