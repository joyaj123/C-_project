@model List<dynamic>

@{
    ViewData["Title"] = "Trips";
}

<link rel="stylesheet" href="~/css/home.css?v=3" />

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <div class="brand">
            <div class="logo">B</div>
            <span>BusBooking</span>
        </div>
        <h2>Available Trips</h2>
    </div>

    <!-- FILTERS (NO RELOAD) -->
    <form class="filters" onsubmit="event.preventDefault(); applyFilters();">

        <select name="fromCityId" id="fromSelect">
            <option value="">From city</option>
            @foreach (var city in ViewBag.Cities)
            {
                <option value="@city.Name">@city.Name</option>
            }
        </select>

        <select name="toCityId" id="toSelect">
            <option value="">To city</option>
            @foreach (var city in ViewBag.Cities)
            {
                <option value="@city.Name">@city.Name</option>
            }
        </select>

        <div class="filter-actions">
            <button type="submit" class="search-btn">Search</button>
            <button type="button" class="reset-btn" onclick="resetFilters()">Reset</button>
        </div>

    </form>

    <!-- TRIPS -->
    <div class="trips" id="tripsContainer">
        <!-- JS renders here -->
    </div>

    <!-- TICKETS -->
<!-- TICKETS -->
<div class="tickets">

    <div class="tickets-header">
        <h2>Your Tickets</h2>

    <a asp-controller="BuyTicket" asp-action="Buy" class="buy-ticket-btn">
    + Buy Ticket
</a>
    </div>

    @foreach (var ticket in ViewBag.Tickets)
    {
        <div class="ticket-card @(ticket.IsActive ? "active" : "")">
            <p><strong>@ticket.Type</strong> - $@ticket.Price</p>

            @if (ticket.IsActive)
            {
                <p class="active-text">Active until @ticket.ExpiresAt</p>
            }
            else
            {
                <form method="post" asp-action="ActivateTicket">
                    <input type="hidden" name="ticketId" value="@ticket.Id" />
                    <button type="submit">Activate</button>
                </form>
            }
        </div>
    }

</div>

</div>

<script>
    // ===========================
    // DATA FROM RAZOR → JS
    // ===========================
    const allTrips = [
        @foreach (var trip in Model)
        {
            <text>
            {
                from: "@trip.FromCity",
                to: "@trip.ToCity",
                bus: "@trip.BusName",
                time: "@trip.DepartureTime",
                price: "@trip.Price"
            },
            </text>
        }
    ];

    const canTravel = @ViewBag.CanTravel.ToString().ToLower();

    // ===========================
    // INITIAL RENDER
    // ===========================
    document.addEventListener("DOMContentLoaded", () => {
        renderTrips(allTrips);
    });

    // ===========================
    // FILTER FUNCTION
    // ===========================
    function applyFilters() {
        const from = document.getElementById("fromSelect").value;
        const to = document.getElementById("toSelect").value;

        const filtered = allTrips.filter(t => {
            return (!from || t.from === from) &&
                   (!to || t.to === to);
        });

        renderTrips(filtered);
    }

    function resetFilters() {
        document.getElementById("fromSelect").value = "";
        document.getElementById("toSelect").value = "";
        renderTrips(allTrips);
    }

    // ===========================
    // RENDER TRIPS
    // ===========================
    function renderTrips(trips) {
        const container = document.getElementById("tripsContainer");

        if (trips.length === 0) {
            container.innerHTML = `
                <div style="grid-column:1/-1;text-align:center;padding:2rem;">
                    No trips found
                </div>`;
            return;
        }

        container.innerHTML = trips.map(t => `
            <div class="trip-card">
                <h3>${t.from} → ${t.to}</h3>
                <p><strong>Bus:</strong> ${t.bus}</p>
                <p><strong>Time:</strong> ${t.time}</p>
                <p><strong>Price:</strong> $${t.price}</p>

                ${!canTravel ? `<p class="disabled">No active ticket</p>` : ``}
            </div>
        `).join('');
    }
</script>