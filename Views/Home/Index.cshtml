@model List<dynamic>

<h1>🚍 Bus Dashboard</h1>

<!-- 🎫 TICKET -->
<div style="padding:15px; border:1px solid black; margin-bottom:20px;">
    <h2>🎫 Ticket</h2>

    @if (ViewBag.Ticket == null)
    {
        <p style="color:red;">❌ No ticket</p>
        <button>Buy Ticket</button>
    }
    else
    {
        var t = ViewBag.Ticket;

        <p>Type: @t.Type</p>
        <p>Price: $@t.Price</p>

        @if (!t.IsActive)
        {
            <p style="color:orange;">⚠️ Ticket not activated</p>
            <button>Activate Ticket</button>
        }
        else if (t.ExpiresAt != null && DateTime.Now > t.ExpiresAt)
        {
            <p style="color:red;">❌ Ticket expired</p>
        }
        else
        {
            <p style="color:green;">
                ✅ Active until @t.ExpiresAt
            </p>
        }
    }
</div>

<!-- 🚍 TRIPS -->
<h2>Trips</h2>

<div style="display:flex; flex-wrap:wrap; gap:10px;">

@foreach (var trip in Model)
{
    <div style="border:1px solid #ccc; padding:10px; width:250px;">
        <h3>@trip.BusName</h3>
        <p>@trip.FromCity → @trip.ToCity</p>
        <p>@trip.DepartureTime</p>
        <p>$@trip.Price</p>

        @{
            var t = ViewBag.Ticket;

            bool canTravel = t != null
                && t.IsActive
                && (t.ExpiresAt == null || DateTime.Now < t.ExpiresAt);
        }

        @if (canTravel)
        {
            <p style="color:green;">✅ You can travel</p>
            <button>Book</button>
        }
        else
        {
            <p style="color:red;">❌ Ticket required</p>
        }
    </div>
}

</div>