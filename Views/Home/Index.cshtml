@model List<dynamic>

<h1>🚍 Bus Dashboard</h1>

@if (TempData["Error"] != null)
{
    <p style="color:red;">@TempData["Error"]</p>
}

@if (TempData["Success"] != null)
{
    <p style="color:green;">@TempData["Success"]</p>
}

<!--  TICKET SECTION -->
<div style="padding:15px; border:1px solid black; margin-bottom:20px;">

    <h2>🎫 My Tickets</h2>

    <!--  BUY BUTTON -->
    <div style="margin-bottom:10px;">
        <a href="/BuyTicket/Buy">
            <button type="button" style="background:green; color:white; padding:8px 12px;">
                ➕ Buy Ticket
            </button>
        </a>
    </div>

    @if (ViewBag.Tickets == null || ViewBag.Tickets.Count == 0)
    {
        <p style="color:red;">❌ No tickets available</p>
    }
    else
    {
        <div style="display:flex; flex-wrap:wrap; gap:10px;">

        @foreach (var t in ViewBag.Tickets)
        {
            <div style="border:1px solid black; padding:10px; width:220px;">
                <p><strong>Type:</strong> @t.Type</p>
                <p><strong>Price:</strong> $@t.Price</p>

                @if (!t.IsActive)
                {
                    <p style="color:orange;">⚠️ Not activated</p>

                    <form method="post" asp-action="ActivateTicket" asp-controller="Home"
                          onsubmit="return confirm('Activate this ticket?');">
                        <input type="hidden" name="ticketId" value="@t.Id" />
                        <button type="submit">Activate</button>
                    </form>
                }
                else if (t.ExpiresAt != null && DateTime.Now > t.ExpiresAt)
                {
                    <p style="color:red;">❌ Expired</p>
                }
                else
                {
                    <p style="color:green;">✅ Active until @t.ExpiresAt</p>
                }
            </div>
        }

        </div>
    }
</div>

<!--  SEARCH TRIPS -->
<div style="padding:15px; border:1px solid black; margin-bottom:20px;">
    <h2>🔍 Search Trips</h2>

    <form method="get" asp-action="Index" asp-controller="Home"
          style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">

        <div>
            <label>From</label><br />
            <select name="fromCityId">
                <option value="">All</option>
                @foreach (var city in ViewBag.Cities)
                {
                    if (ViewBag.SelectedFromCityId != null && (int)ViewBag.SelectedFromCityId == city.Id)
                    {
                        <option value="@city.Id" selected>@city.Name</option>
                    }
                    else
                    {
                        <option value="@city.Id">@city.Name</option>
                    }
                }
            </select>
        </div>

        <div>
            <label>To</label><br />
            <select name="toCityId">
                <option value="">All</option>
                @foreach (var city in ViewBag.Cities)
                {
                    if (ViewBag.SelectedToCityId != null && (int)ViewBag.SelectedToCityId == city.Id)
                    {
                        <option value="@city.Id" selected>@city.Name</option>
                    }
                    else
                    {
                        <option value="@city.Id">@city.Name</option>
                    }
                }
            </select>
        </div>

        <div style="margin-top:18px;">
            <button type="submit">Search</button>
            <a asp-action="Index" asp-controller="Home" style="margin-left:10px;">Reset</a>
        </div>
    </form>
</div>

<!--  TRIPS -->
<h2>Trips</h2>

@if (Model.Count == 0)
{
    <p style="color:gray;">No trips found.</p>
}
else
{
    <div style="display:flex; flex-wrap:wrap; gap:10px;">

    @foreach (var trip in Model)
    {
        <div style="border:1px solid #ccc; padding:10px; width:250px;">
            <h3>@trip.BusName</h3>
            <p>@trip.FromCity → @trip.ToCity</p>
            <p>@trip.DepartureTime</p>
            <p>$@trip.Price</p>

            @{
                var tickets = ViewBag.Tickets as List<dynamic>;

                bool canTravel = tickets != null && tickets.Any(t =>
                    t.IsActive &&
                    (t.ExpiresAt == null || DateTime.Now <= t.ExpiresAt)
                );
            }

            @if (!canTravel)
            {
                <p style="color:red;">❌ No valid ticket</p>
            }
        </div>
    }

    </div>
}