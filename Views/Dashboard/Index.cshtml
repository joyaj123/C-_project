@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - BusBooking</title>
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>

<body>
    <div class="page">

        <!-- HERO SECTION -->
        <div class="hero">
            <div class="navbar">
                <div class="brand">
                    <div class="logo">B</div>
                    <span>BusBooking</span>
                </div>
            </div>

            <div class="hero-content">
                <div class="text">
                    <h1>Explore Lebanon<br />the smarter way.</h1>
                    <p>
                        Book bus tickets, manage trips, and travel easily across cities
                        with our simple and modern platform.
                    </p>

                    <a href="/Home" class="cta-btn">
                        Go to all trips →
                    </a>
                </div>

                
            </div>
        </div>

        <!-- FEATURES -->
        <div class="features">
            <div class="feature">
                <h3>🎫 Easy Ticketing</h3>
                <p>Book your tickets in seconds with a smooth experience.</p>
            </div>

            <div class="feature">
                <h3>⚡ Instant Activation</h3>
                <p>Activate your tickets anytime and start traveling.</p>
            </div>

            <div class="feature">
                <h3>🧭 Smart Trips</h3>
                <p>Filter trips by city and find the best route instantly.</p>
            </div>
        </div>

    </div>
</body>
</html>