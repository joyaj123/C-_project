@model BusBookingSystem.Models.User

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Bus Booking System</title>
    <link rel="stylesheet" href="~/css/register.css" />
</head>

<body>
    <div class="page">
        <!-- LEFT SIDE (same as login) -->
        <div class="left-panel">
            <div class="brand">
                <div class="logo">B</div>
                <span>BusBooking</span>
            </div>

            <div class="hero-text">
                <h1>Start your journey,<br />join today.</h1>
                <p>Create your account and book trips in seconds.</p>
            </div>
        </div>

        <!-- RIGHT SIDE -->
        <div class="right-panel">
            <div class="register-card">
                <h2>Create account</h2>
                <p class="subtitle">Fill in your details to get started.</p>

                @if (ViewBag.Error != null)
                {
                    <div class="error-box">
                        @ViewBag.Error
                    </div>
                }

                <form method="post" asp-controller="Register" asp-action="Register">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label>Username</label>
                        <input type="text" name="Username" value="@Model?.Username" required />
                    </div>

                    <div class="form-group">
                        <label>Email address</label>
                        <input type="email" name="Email" value="@Model?.Email" required />
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="Password" required />
                    </div>

                    <div class="form-group">
                        <label>Confirm Password</label>
                        <input type="password" name="ConfirmPassword" required />
                    </div>
                    <button type="submit" class="login-btn">Sign up</button>
                </form>

                <p class="register-text">
                    Already have an account?
                    <a asp-controller="LogIn" asp-action="Login">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</body>
</html>