<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BusBooking</title>

    <!-- ONLY YOUR CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- OPTIONAL HEADER (hidden clean app style) -->
    <header></header>

    <!-- FULL WIDTH APP CONTAINER -->
    <main>
        @RenderBody()
    </main>

    <!-- REMOVE FOOTER COMPLETELY -->
    <footer style="display:none;"></footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
