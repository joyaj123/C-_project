@model BusBookingSystem.Models.Trip

@{
    ViewData["Title"] = "Add Trip";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Trip</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <style>
        body {
            background: #f5f7fb;
            font-family: Arial, sans-serif;
        }

        .form-container {
            max-width: 650px;
            margin: 60px auto;
            background: white;
            padding: 35px;
            border-radius: 14px;
            box-shadow: 0 4px 18px rgba(0,0,0,0.08);
        }

        h2 {
            font-weight: bold;
            margin-bottom: 25px;
        }

        label {
            font-weight: 600;
            margin-bottom: 6px;
        }

        .btn-group-custom {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <div class="container">

        <div class="form-container">

            <h2>Add New Trip</h2>

            <form method="post">

                <!-- BUS -->
                <div class="mb-3">
                    <label>Bus</label>

                    <select asp-for="BusId" class="form-select" required>

                        <option value="">
                            Select Bus
                        </option>

                        @foreach (var bus in ViewBag.Buses)
                        {
                            <option value="@bus.Id">
                                @bus.Name
                            </option>
                        }

                    </select>
                </div>

                <!-- ROUTE -->
                <div class="mb-3">
                    <label>Route</label>

                    <select asp-for="RouteId" class="form-select" required>

                        <option value="">
                            Select Route
                        </option>

                        @foreach (var route in ViewBag.Routes)
                        {
                            <option value="@route.Id">
                                @route.RouteName
                            </option>
                        }

                    </select>
                </div>

                <!-- DEPARTURE -->
                <div class="mb-3">
                    <label>Departure Time</label>

                    <input asp-for="DepartureTime"
                           type="datetime-local"
                           class="form-control"
                           required />
                </div>

             

                <!-- BUTTONS -->
                <div class="btn-group-custom">

                    <button type="submit"
                            class="btn btn-success">
                        Add Trip
                    </button>

                    <a href="/Admin/Admin"
                       class="btn btn-secondary">
                        Cancel
                    </a>

                </div>

            </form>

        </div>

    </div>

</body>
</html>