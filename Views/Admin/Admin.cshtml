@model List<BusBookingSystem.Models.Trip>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f5f7fb;
            font-family: Arial, sans-serif;
        }

        .navbar {
            background-color: #0d6efd;
        }

        .navbar-brand {
            color: white;
            font-weight: bold;
        }

        .container-box {
            background: white;
            padding: 30px;
            border-radius: 12px;
            margin-top: 40px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

        .top-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        h2 {
            font-weight: bold;
            margin-bottom: 8px;
        }

        .badge-admin {
            background-color: #198754;
            padding: 8px 14px;
            border-radius: 30px;
            color: white;
            font-size: 14px;
        }

        .route-text {
            font-weight: 600;
            color: #0d6efd;
        }

        .bus-text {
            font-weight: 600;
        }

        .price-text {
            font-weight: bold;
            color: #198754;
        }

        .btn-action {
            margin-right: 5px;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/Admin/Admin">
                BusBooking Admin
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="container-box">

            <div class="top-actions">
                <div>
                    <h2>Manage Trips</h2>
                    <span class="badge-admin">Admin Panel</span>
                </div>

                <a href="/Admin/Create" class="btn btn-primary">
                    + Add Trip
                </a>
            </div>

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Bus</th>
                        <th>Route</th>
                        <th>Departure Time</th>
                        <th width="220">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No trips found
                            </td>
                        </tr>
                    }

                    @foreach (var trip in Model)
                    {
                        <tr>
                            <td>@trip.Id</td>

                            <td class="bus-text">
                                @trip.BusName
                            </td>

                            <td class="route-text">
                                @trip.RouteName
                            </td>

                            <td>
                                @trip.DepartureTime.ToString("yyyy-MM-dd HH:mm")
                            </td>


                            <td>
                                <a href="/Admin/Edit/@trip.Id"
                                   class="btn btn-warning btn-sm btn-action">
                                    Edit
                                </a>

                                <a href="/Admin/Delete/@trip.Id"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this trip?')">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</body>
</html>