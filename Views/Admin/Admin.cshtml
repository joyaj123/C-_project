@model List<BusBookingSystem.Models.Trip>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link href="~/css/admin.css" rel="stylesheet" />
</head>

<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/Admin/Admin">
                BusBooking Admin
            </a>
        </div>
    </nav>

    <div class="container">
        <div class="container-box">

            <div class="top-actions">
                <div>
                    <h2>Manage Trips</h2>
                    <span class="badge-admin">Admin Panel</span>
                </div>

                <a href="/Admin/Create" class="btn btn-primary">
                    + Add Trip
                </a>
            </div>
            <!-- DELETE MODAL -->
<div id="deleteModal" class="custom-modal">
    <div class="custom-modal-content">

        <h3>Delete Trip</h3>

        <p>
            Are you sure you want to delete this trip?
        </p>

        <div class="modal-actions">

            <button class="btn-cancel"
                    onclick="closeDeleteModal()">
                Cancel
            </button>

            <a id="confirmDeleteBtn"
               href="#"
               class="btn-delete-confirm">
                Delete
            </a>

        </div>
    </div>
</div>

            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Bus</th>
                        <th>Route</th>
                        <th>Departure Time</th>
                        <th width="220">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No trips found
                            </td>
                        </tr>
                    }

                    @foreach (var trip in Model)
                    {
                        <tr>
                            <td>@trip.Id</td>

                            <td class="bus-text">
                                @trip.BusName
                            </td>

                            <td class="route-text">
                                @trip.RouteName
                            </td>

                            <td>
                                @trip.DepartureTime.ToString("yyyy-MM-dd HH:mm")
                            </td>


                            <td>
                                <a href="/Admin/Edit/@trip.Id"
                                   class="btn btn-warning btn-sm btn-action">
                                    Edit
                                </a>

                                <button class="btn btn-danger btn-sm"
                                 onclick="openDeleteModal(@trip.Id)">
                                Delete
                               </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
<script>
    function openDeleteModal(id) {

        document.getElementById("deleteModal").style.display = "flex";

        document.getElementById("confirmDeleteBtn").href =
            "/Admin/Delete/" + id;
    }

    function closeDeleteModal() {

        document.getElementById("deleteModal").style.display = "none";
    }

    // close when clicking outside
    window.onclick = function (event) {

        let modal = document.getElementById("deleteModal");

        if (event.target === modal) {
            closeDeleteModal();
        }
    }
   </script>
</body>
</html>